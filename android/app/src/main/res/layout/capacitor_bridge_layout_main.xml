<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/native_root"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/native_shell_surface"
    android:orientation="vertical">

    <LinearLayout
        android:id="@+id/native_top_bar"
        android:layout_width="match_parent"
        android:layout_height="58dp"
        android:background="@color/native_shell_surface"
        android:elevation="2dp"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:paddingStart="18dp"
        android:paddingEnd="10dp"
        android:visibility="gone">

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical">

            <TextView
                android:id="@+id/native_eyebrow"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:fontFamily="sans-serif-medium"
                android:letterSpacing="0.12"
                android:textColor="@color/native_shell_muted"
                android:textSize="10sp" />

            <TextView
                android:id="@+id/native_title"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="1dp"
                android:ellipsize="end"
                android:fontFamily="sans-serif-medium"
                android:maxLines="1"
                android:textColor="@color/native_shell_ink"
                android:textSize="18sp" />
        </LinearLayout>

        <ImageButton
            android:id="@+id/native_profile_button"
            android:layout_width="42dp"
            android:layout_height="42dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:contentDescription="我的"
            android:padding="12dp"
            android:src="@drawable/ic_native_profile"
            android:tint="@color/native_shell_ink" />
    </LinearLayout>

    <com.getcapacitor.CapacitorWebView
        android:id="@+id/webview"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:background="@color/native_shell_surface" />

    <LinearLayout
        android:id="@+id/native_bottom_navigation"
        android:layout_width="match_parent"
        android:layout_height="64dp"
        android:background="@drawable/native_bottom_bar_background"
        android:elevation="14dp"
        android:gravity="center"
        android:orientation="horizontal"
        android:paddingStart="8dp"
        android:paddingTop="6dp"
        android:paddingEnd="8dp"
        android:paddingBottom="6dp"
        android:visibility="gone"
        android:weightSum="5">

        <TextView
            android:id="@+id/nav_chat"
            style="@style/NativeNavigationItem"
            android:drawableTop="@drawable/ic_native_chat"
            android:text="对话" />

        <TextView
            android:id="@+id/nav_library"
            style="@style/NativeNavigationItem"
            android:drawableTop="@drawable/ic_native_library"
            android:text="文档" />

        <TextView
            android:id="@+id/nav_sources"
            style="@style/NativeNavigationItem"
            android:drawableTop="@drawable/ic_native_sources"
            android:text="引用" />

        <TextView
            android:id="@+id/nav_graph"
            style="@style/NativeNavigationItem"
            android:drawableTop="@drawable/ic_native_graph"
            android:text="图谱" />

        <TextView
            android:id="@+id/nav_profile"
            style="@style/NativeNavigationItem"
            android:drawableTop="@drawable/ic_native_profile"
            android:text="我的" />
    </LinearLayout>
</LinearLayout>
